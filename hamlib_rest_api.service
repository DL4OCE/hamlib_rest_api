[Unit]
Description=Hamlib REST API and web GUI service
After=network.target

[Service]
Type=simple
User={{USER}}
Group={{USER}}
ExecStart=/usr/local/bin/hamlib_rest_api
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hamlib_rest_api

[Install]
WantedBy=multi-user.target